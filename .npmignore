# Exclude TypeScript sources and dev files from the published npm package.
# The compiled JS in setup/ is included (generated by prepublishOnly).

# Worker source (consumers don't need this — it's deployed separately to Cloudflare)
worker/node_modules/
worker/src/
worker/package-lock.json

# Deployer TypeScript sources
deployers/**/*.ts

# Setup TypeScript sources (compiled JS is included)
setup/*.ts
setup/tsconfig.json
setup/*.d.ts
setup/*.d.ts.map
setup/*.js.map

# Dev / config
tsconfig.json
.gitignore
.eslintrc*
*.log

# Local secrets and config
agent.json
.dev.vars
*.env
.env.*

# Tests and coverage
coverage/
.nyc_output/

# Examples (not needed by package consumers)
examples/
