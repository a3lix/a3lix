---
// Schnitzel Fri3nds — A3lix example one-pager
// All content is loaded from src/content/ — edit those files via Telegram using A3lix.

import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';

const contentDir = join(process.cwd(), 'src/content');

const hero     = JSON.parse(readFileSync(join(contentDir, 'hero.json'), 'utf-8'));
const menu     = JSON.parse(readFileSync(join(contentDir, 'menu.json'), 'utf-8'));
const specials = JSON.parse(readFileSync(join(contentDir, 'specials.json'), 'utf-8'));
const images   = JSON.parse(readFileSync(join(contentDir, 'images.json'), 'utf-8'));

const aboutRaw   = readFileSync(join(contentDir, 'about.md'), 'utf-8');
const aboutTitle = aboutRaw.match(/^#\s+(.+)/m)?.[1] ?? 'Our Story';
const aboutBody  = marked(aboutRaw.replace(/^#\s+.+\n?/m, '').trim());
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Schnitzel Fri3nds — Chicoutimi</title>
  <meta name="description" content="A German-Canadian kitchen in the heart of Chicoutimi. Crispy, golden schnitzel served with pride." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- ═══════════════════════════════════════════════
       NAV
  ══════════════════════════════════════════════════ -->
  <nav class="nav">
    <a href="#" class="nav-logo">Schnitzel Fri3nds</a>
    <ul class="nav-links">
      <li><a href="#menu">Menu</a></li>
      <li><a href="#specials">Specials</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#visit" class="nav-cta">Visit Us</a></li>
    </ul>
  </nav>

  <!-- ═══════════════════════════════════════════════
       HERO — full-bleed photo background
  ══════════════════════════════════════════════════ -->
  <section class="hero" id="home">
    <!-- Background image -->
    <div
      class="hero-bg"
      style={`background-image: url('${images.hero.src}');`}
      role="img"
      aria-label={images.hero.alt}
    ></div>

    <!-- Dark overlay -->
    <div class="hero-overlay"></div>
    <div class="hero-grain"></div>

    <!-- Vertical side labels -->
    <span class="hero-side hero-side--left" aria-hidden="true">CHICOUTIMI · SAGUENAY</span>
    <span class="hero-side hero-side--right" aria-hidden="true">KÜCHE & GEMÜTLICHKEIT</span>

    <div class="hero-content">
      <p class="hero-badge">{hero.badge}</p>
      <h1 class="hero-headline">{hero.headline}</h1>
      <p class="hero-tagline">{hero.tagline}</p>
      <p class="hero-sub">{hero.subtext}</p>
      <a href={hero.ctaHref} class="hero-btn">{hero.ctaLabel}</a>
    </div>

    <div class="hero-scroll-hint" aria-hidden="true">
      <span>↓</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       GALLERY STRIP — three images after hero
  ══════════════════════════════════════════════════ -->
  <div class="gallery-strip">
    {images.gallery.map((img: { src: string; alt: string }) => (
      <div class="gallery-frame">
        <img src={img.src} alt={img.alt} loading="lazy" />
      </div>
    ))}
  </div>

  <!-- ═══════════════════════════════════════════════
       MENU
  ══════════════════════════════════════════════════ -->
  <section class="menu" id="menu">
    <div class="section-header">
      <span class="section-label">The Menu</span>
      <h2 class="section-title">what we make</h2>
    </div>

    {menu.categories.map((category: { name: string; items: { name: string; description: string; price: string }[] }) => (
      <div class="menu-category">
        <h3 class="menu-category-name">{category.name}</h3>
        <div class="menu-grid">
          {category.items.map((item: { name: string; description: string; price: string }) => (
            <div class="menu-item">
              <div class="menu-item-top">
                <span class="menu-item-name">{item.name}</span>
                <span class="menu-item-price">{item.price}</span>
              </div>
              <p class="menu-item-desc">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>

  <!-- ═══════════════════════════════════════════════
       SPECIALS
  ══════════════════════════════════════════════════ -->
  <section class="specials" id="specials">
    <div class="specials-inner">
      <div class="section-header section-header--light">
        <span class="section-label section-label--amber">{specials.weekLabel}</span>
        <h2 class="section-title section-title--light">the board</h2>
        <p class="specials-tagline">{specials.tagline}</p>
      </div>

      <div class="specials-list">
        {specials.items.filter((s: { active: boolean }) => s.active).map((special: { day: string; name: string; description: string; price: string }) => (
          <div class="special-item">
            <div class="special-day">{special.day}</div>
            <div class="special-body">
              <div class="special-top">
                <span class="special-name">{special.name}</span>
                <span class="special-price">{special.price}</span>
              </div>
              <p class="special-desc">{special.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       ABOUT — photo left, text right
  ══════════════════════════════════════════════════ -->
  <section class="about" id="about">
    <div class="about-inner">
      <div class="about-visual">
        <img
          src={images.about.src}
          alt={images.about.alt}
          loading="lazy"
          class="about-photo"
        />
        <!-- Overlay editorial label -->
        <div class="about-photo-label" aria-hidden="true">
          <span class="about-visual-de">Guten<br/>Appetit</span>
        </div>
      </div>
      <div class="about-text">
        <span class="section-label">Our Story</span>
        <h2 class="section-title">{aboutTitle.toLowerCase()}</h2>
        <div class="about-prose" set:html={aboutBody} />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       VISIT
  ══════════════════════════════════════════════════ -->
  <section class="visit" id="visit">
    <div class="visit-inner">
      <div class="visit-col">
        <span class="section-label">Find Us</span>
        <address class="visit-address">
          456 Rue Poutine Est<br />
          Chicoutimi, QC · G7H 1S6
        </address>
      </div>
      <div class="visit-col">
        <span class="section-label">Hours</span>
        <ul class="visit-hours">
          <li><span>Mon – Thu</span><span>11:30 – 22:00</span></li>
          <li><span>Fri – Sat</span><span>11:30 – 23:00</span></li>
          <li><span>Dimanche</span><span>12:00 – 21:00</span></li>
        </ul>
      </div>
      <div class="visit-col">
        <span class="section-label">Contact</span>
        <p class="visit-contact">
          <a href="mailto:bonjour@schnitzel-fri3nds.ca">bonjour@schnitzel-fri3nds.ca</a><br />
          <a href="tel:+14185550192">(418) 555-0192</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════════ -->
  <footer class="footer">
    <span class="footer-logo">Schnitzel Fri3nds</span>
    <span class="footer-copy">© 2024 Schnitzel Fri3nds Inc. Chicoutimi, QC</span>
    <span class="footer-powered">
      Powered by <a href="https://github.com/a3lix/a3lix" target="_blank" rel="noopener">A3lix</a>
    </span>
  </footer>

</body>
</html>

<style is:global>
  /* ─── Reset & Base ─────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* Palette */
    --c-bg-dark:    #1A1917;
    --c-bg-mid:     #242220;
    --c-cream:      #F4EFE4;
    --c-cream-dim:  #E8E1D3;
    --c-amber:      #C8892C;
    --c-amber-dim:  #9B6A20;
    --c-text-dark:  #2A2720;
    --c-text-muted: #7A6E60;
    --c-border:     rgba(200,137,44,0.18);

    /* Typography */
    --f-serif: 'Playfair Display', Georgia, serif;
    --f-sans:  'DM Sans', system-ui, sans-serif;

    /* Spacing */
    --gap: clamp(1.5rem, 4vw, 3rem);
    --section-pad: clamp(4rem, 8vw, 7rem);
    --max-w: 1180px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--f-sans);
    background: var(--c-cream);
    color: var(--c-text-dark);
    font-size: 1rem;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  /* ─── Nav ────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem clamp(1.5rem, 5vw, 3rem);
    background: rgba(26, 25, 23, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(200,137,44,0.1);
  }

  .nav-logo {
    font-family: var(--f-serif);
    font-size: 1.1rem;
    color: var(--c-cream);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    color: rgba(244,239,228,0.7);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--c-amber); }

  .nav-cta {
    color: var(--c-amber) !important;
    border: 1px solid var(--c-amber);
    padding: 0.4rem 1rem;
    border-radius: 2px;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--c-amber) !important; color: var(--c-bg-dark) !important; }

  /* ─── Hero ───────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 8rem var(--gap) 4rem;
  }

  /* Full-bleed photo */
  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
    transform: scale(1.04);
    transition: transform 8s ease-out;
  }

  .hero:hover .hero-bg { transform: scale(1.0); }

  /* Dark overlay */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(20,18,14,0.55) 0%, rgba(20,18,14,0.75) 100%),
      radial-gradient(ellipse 70% 50% at 50% 50%, rgba(0,0,0,0.0) 0%, rgba(0,0,0,0.4) 100%);
  }

  /* Film-grain texture */
  .hero-grain {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    background-size: 256px;
    pointer-events: none;
    opacity: 0.5;
    mix-blend-mode: overlay;
  }

  /* Vertical side text */
  .hero-side {
    position: absolute;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(244,239,228,0.3);
    writing-mode: vertical-rl;
    font-family: var(--f-sans);
    font-weight: 300;
    z-index: 2;
  }

  .hero-side--left  { left: 1.75rem; bottom: 6rem; text-orientation: mixed; transform: rotate(180deg); }
  .hero-side--right { right: 1.75rem; top: 8rem; }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-amber);
    border: 1px solid var(--c-border);
    padding: 0.35rem 1rem;
    border-radius: 2px;
    margin-bottom: 1.75rem;
    font-weight: 400;
  }

  .hero-headline {
    font-family: var(--f-serif);
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 700;
    line-height: 1.0;
    color: var(--c-cream);
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
    text-shadow: 0 2px 24px rgba(0,0,0,0.4);
  }

  .hero-tagline {
    font-family: var(--f-serif);
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: var(--c-amber);
    font-weight: 400;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1rem;
    color: rgba(244,239,228,0.6);
    font-weight: 300;
    max-width: 440px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .hero-btn {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    background: var(--c-amber);
    color: var(--c-bg-dark);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.2s, transform 0.15s;
  }

  .hero-btn:hover { background: #E09A35; transform: translateY(-1px); }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(244,239,228,0.3);
    font-size: 1.1rem;
    z-index: 2;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ─── Gallery Strip ──────────────────────────── */
  .gallery-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    height: clamp(220px, 30vw, 380px);
    overflow: hidden;
  }

  .gallery-frame {
    overflow: hidden;
    position: relative;
  }

  .gallery-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-frame:hover img { transform: scale(1.05); }

  /* ─── Section Shared ─────────────────────────── */
  .section-label {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-amber);
    font-weight: 500;
    margin-bottom: 0.6rem;
  }

  .section-title {
    font-family: var(--f-serif);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--c-text-dark);
    margin-bottom: 3rem;
  }

  .section-title--light { color: var(--c-cream); }

  .section-header {
    max-width: var(--max-w);
    margin: 0 auto 1rem;
    padding: 0 var(--gap);
  }

  /* ─── Menu ───────────────────────────────────── */
  .menu {
    background: var(--c-cream);
    padding: var(--section-pad) 0;
  }

  .menu-category {
    max-width: var(--max-w);
    margin: 0 auto 4rem;
    padding: 0 var(--gap);
  }

  .menu-category-name {
    font-family: var(--f-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-text-muted);
    font-weight: 500;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--c-cream-dim);
    margin-bottom: 1.5rem;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 460px), 1fr));
    gap: 1px;
    background: var(--c-cream-dim);
    border: 1px solid var(--c-cream-dim);
  }

  .menu-item {
    background: var(--c-cream);
    padding: 1.5rem 1.75rem;
    transition: background 0.18s;
  }

  .menu-item:hover { background: #EDE8DC; }

  .menu-item-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.45rem;
  }

  .menu-item-name {
    font-family: var(--f-serif);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--c-text-dark);
  }

  .menu-item-price {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--c-amber-dim);
    white-space: nowrap;
  }

  .menu-item-desc {
    font-size: 0.875rem;
    color: var(--c-text-muted);
    line-height: 1.55;
  }

  /* ─── Specials ───────────────────────────────── */
  .specials {
    background: var(--c-bg-dark);
    padding: var(--section-pad) 0;
  }

  .specials-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gap);
  }

  .specials-tagline {
    font-family: var(--f-serif);
    font-style: italic;
    font-size: 1rem;
    color: rgba(244,239,228,0.4);
    margin-top: -2rem;
    margin-bottom: 3rem;
  }

  .specials-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(200,137,44,0.2);
  }

  .special-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid rgba(200,137,44,0.12);
    transition: padding-left 0.15s;
  }

  .special-item:hover { padding-left: 0.5rem; }

  .special-day {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-amber);
    font-weight: 400;
    padding-top: 0.2rem;
  }

  .special-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .special-name {
    font-family: var(--f-serif);
    font-size: 1.2rem;
    color: var(--c-cream);
    font-weight: 400;
  }

  .special-price {
    font-size: 0.95rem;
    color: var(--c-amber);
    font-weight: 500;
    white-space: nowrap;
  }

  .special-desc {
    font-size: 0.875rem;
    color: rgba(244,239,228,0.45);
    line-height: 1.55;
  }

  /* ─── About ──────────────────────────────────── */
  .about {
    background: var(--c-cream);
    padding: var(--section-pad) 0;
    overflow: hidden;
  }

  .about-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gap);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 8vw, 7rem);
    align-items: center;
  }

  .about-visual {
    position: relative;
    height: clamp(360px, 50vw, 560px);
    overflow: hidden;
    border-radius: 2px;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s ease;
  }

  .about-visual:hover .about-photo { transform: scale(1.04); }

  /* Editorial overlay label on the photo */
  .about-photo-label {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    pointer-events: none;
  }

  .about-visual-de {
    font-family: var(--f-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.0;
    color: rgba(244,239,228,0.9);
    text-shadow: 0 2px 16px rgba(0,0,0,0.5);
    letter-spacing: -0.02em;
  }

  .about-text .section-title { margin-bottom: 1.5rem; }

  .about-prose {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--c-text-muted);
  }

  .about-prose p { margin-bottom: 1.1rem; }
  .about-prose p:last-child { margin-bottom: 0; }
  .about-prose strong { color: var(--c-text-dark); font-weight: 500; }
  .about-prose em { font-style: italic; }

  /* ─── Visit ──────────────────────────────────── */
  .visit {
    background: var(--c-bg-dark);
    padding: var(--section-pad) 0;
    border-top: 1px solid rgba(200,137,44,0.12);
  }

  .visit-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gap);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .visit-col .section-label { margin-bottom: 1rem; }

  .visit-address {
    font-style: normal;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(244,239,228,0.6);
  }

  .visit-hours {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .visit-hours li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.875rem;
    color: rgba(244,239,228,0.55);
    border-bottom: 1px solid rgba(200,137,44,0.08);
    padding-bottom: 0.5rem;
  }

  .visit-hours li span:first-child { color: rgba(244,239,228,0.35); }

  .visit-contact {
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .visit-contact a {
