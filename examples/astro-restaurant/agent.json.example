{
  "project": {
    "name": "Schnitzel Fri3nds",
    "repo": "YOUR_GITHUB_USERNAME/schnitzel-fri3nds",
    "branch": "main",
    "framework": "astro"
  },
  "bot": {
    "platform": "telegram",
    "ownerChatId": "YOUR_TELEGRAM_CHAT_ID"
  },
  "ai": {
    "provider": "grok",
    "model": "grok-2-latest",
    "apiKey": "YOUR_XAI_API_KEY"
  },
  "paths": {
    "allowed": [
      "src/content"
    ]
  },
  "roles": {
    "editors": [],
    "viewers": []
  },
  "limits": {
    "changesPerUserPerDay": 10,
    "previewExpiryHours": 48,
    "requireApprovalForAll": true
  },
  "cloudflare": {
    "pagesProjectName": "schnitzel-fri3nds",
    "customDomain": "schnitzel-fri3nds.com"  // Optional: custom domain for your site
  }
}
