# ============================================================
# A3lix — .gitignore
# ============================================================

# ------------------------------------------------------------
# CRITICAL: Never commit these — they contain secrets
# ------------------------------------------------------------
agent.json
.dev.vars
*.env
.env.*
.env

# ------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------
node_modules/
.pnpm-store/

# ------------------------------------------------------------
# Build output
# ------------------------------------------------------------
dist/
build/
out/

# ------------------------------------------------------------
# Wrangler / Cloudflare
# ------------------------------------------------------------
.wrangler/
wrangler.json.lock

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Test coverage
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# OS artefacts
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------
# Editor / IDE
# ------------------------------------------------------------
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
